{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/migrations/**",
    "**/routeTree.gen.ts",
    ".output/**",
    ".nitro/**",
    ".claude/**"
  ],
  "singleQuote": true,
  "sortImports": {
    "customGroups": [
      { "groupName": "exhibit-internal", "elementNamePattern": ["@/**", "@testing/**"] },
      {
        "groupName": "react",
        "elementNamePattern": ["react", "react/**", "react-dom", "react-dom/**"]
      }
    ],
    "groups": [
      ["builtin", "type-builtin"],
      ["react"],
      ["external", "type-external"],
      ["side_effect-external"],
      ["exhibit-internal"],
      ["internal", "type-internal", "parent", "type-parent", "sibling", "type-sibling"],
      ["side_effect-internal", "side_effect-parent", "side_effect-sibling"],
      ["index", "type-index"],
      ["side_effect-index"],
      ["style"],
      ["unknown"]
    ],
    "newlinesBetween": true,
    "internalPattern": []
  },
  "sortTailwindcss": { "functions": ["cn", "cva"] }
}
