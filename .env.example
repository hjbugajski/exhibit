# Secret used by Better Auth for signing sessions/tokens. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL the app is served at; used as Better Auth's baseURL and OAuth
# issuer/audience. NOTE: this app deliberately reads BASE_URL, not Better
# Auth's conventional BETTER_AUTH_URL — setting the latter does nothing.
BASE_URL=http://localhost:3000

# Path to the SQLite database file. (The Docker image defaults this to
# /data/app.db, inside its declared volume.)
DATABASE_PATH=./data/app.db

# Owner account credentials. Read at server boot: the owner account is
# created only when no user exists yet; a later boot with a different
# OWNER_EMAIL does not create a second account. Also consumed by `pnpm seed`
# for manual seeding from a source checkout.
OWNER_EMAIL=
OWNER_PASSWORD=

# Where the drizzle migrations live; only override if you relocate them.
# Defaults to <cwd>/src/database/migrations, which matches both a source
# checkout and the Docker image layout.
# MIGRATIONS_PATH=

# Optional: outbound email via Resend (https://resend.com). When both are
# set, the login page offers "Forgot password?" and email changes send a
# verification link. Leave empty to run without outbound email — password
# and email can still be changed from /settings while signed in.
# EMAIL_FROM must be a sender on a domain verified in your Resend account,
# e.g. "Exhibit <exhibit@yourdomain.com>".
RESEND_API_KEY=
EMAIL_FROM=

# Optional: API key from https://protomaps.com (free for non-commercial use).
# When set, Map blocks render the house-styled Protomaps basemap; leave empty
# to fall back to Carto's stock light/dark styles. Add your deployment origin
# to the key's CORS allowlist (localhost is always allowed).
PROTOMAPS_API_KEY=

# Optional: comma-separated IPs/CIDRs of reverse proxies in front of the app,
# e.g. "10.0.0.1,192.168.0.0/24". Scopes which forwarded hops login/reset
# rate limiting trusts for the client IP. Leave empty only if you are not
# behind a proxy that sets X-Forwarded-For, or you accept it being spoofable.
TRUSTED_PROXIES=
